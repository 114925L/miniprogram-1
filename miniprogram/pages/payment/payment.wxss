/* pages/payment/payment.wxss */
.payment-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 顶部摘要 */
.pay-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  padding: 60rpx 40rpx 50rpx;
}

.ph-order {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.ph-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.ph-no {
  font-size: 24rpx;
  color: #fff;
  font-family: 'Courier New', monospace;
}

.ph-amount {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ph-amount-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.ph-price {
  display: flex;
  align-items: baseline;
}

.ph-currency {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.ph-num {
  font-size: 80rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

/* 通用区块 */
.section {
  background: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 支付方式 */
.pay-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.pay-option.active {
  border-color: #FF6B35;
  background: #fff5f0;
}

.pm-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.pm-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.pm-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pm-check::after {
  content: '✓';
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

/* 提示 */
.pay-tips-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fffbe6;
  margin-top: 20rpx;
  padding: 24rpx 30rpx;
}

.pt-icon {
  font-size: 36rpx;
}

.pt-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部操作栏 */
.pay-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.pay-btn-cancel {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: 2rpx solid #e5e5e5;
  background: #fff;
  font-size: 30rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.pay-btn-confirm {
  flex: 2;
  height: 88rpx;
  border-radius: 44rpx;
  background: #FF6B35;
  font-size: 30rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.pay-btn-cancel:active,
.pay-btn-confirm:active {
  opacity: 0.85;
}
