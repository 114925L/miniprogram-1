/* pages/order/order.wxss */
.order-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 通用区块 */
.section {
  background: #fff;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 商品列表 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-item-card {
  display: flex;
  gap: 20rpx;
}

.item-emoji {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-emoji text {
  font-size: 56rpx;
}

.item-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.item-specs {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.topping-tag {
  color: #FF6B35;
  font-weight: 500;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 2rpx solid #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.qty-btn text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 700;
  line-height: 1;
}

.qty-value {
  font-size: 28rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

.item-qty {
  font-size: 24rpx;
  color: #999;
}

.item-total {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B35;
}

/* 优惠券 */
.coupon-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.cs-label {
  font-size: 26rpx;
  color: #666;
}

.cs-arrow {
  font-size: 24rpx;
  color: #ccc;
}

.coupon-dropdown {
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.coupon-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  font-size: 26rpx;
  color: #333;
}

.check {
  color: #FF6B35;
  font-size: 28rpx;
}

.coupon-empty {
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #ccc;
}

/* 价格明细 */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.text-gray { color: #ccc; }
.text-green { color: #52C41A; }

.price-total {
  margin-top: 16rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
}

/* 支付方式 */
.payment-option {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}

.pay-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.pay-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.pay-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #FF6B35;
  position: relative;
}

.pay-check::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 20rpx;
  color: #fff;
}

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 200;
}

.submit-info {
  display: flex;
  align-items: baseline;
}

.si-label {
  font-size: 24rpx;
  color: #666;
}

.si-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-left: 8rpx;
}

.submit-btn {
  padding: 0 60rpx;
  height: 80rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  opacity: 0.85;
}
