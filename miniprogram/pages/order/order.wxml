<!--pages/order/order.wxml-->
<view class="order-page">
  <!-- 商品摘要 -->
  <view class="section order-items-section">
    <view class="section-title">商品信息</view>
    <view class="item-list">
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="order-item-card"
      >
        <view class="item-emoji placeholder-bg" style="background: {{item.bgGradient}}">
          <text>{{item.image}}</text>
        </view>
        <view class="item-detail">
          <text class="item-name">{{item.name}}</text>
          <view class="item-specs">
            <text wx:if="{{item.sweetness}}">{{item.sweetness}}</text>
            <text wx:if="{{item.sweetness && item.temperature}}"> / </text>
            <text wx:if="{{item.temperature}}">{{item.temperature}}</text>
            <text wx:if="{{item.size}}"> · {{item.size}}</text>
            <text wx:if="{{item.toppings && item.toppings.length}}"> · +{{item.toppings.join(',')}}</text>
          </view>
          <view class="item-bottom">
            <view class="qty-control">
              <view class="qty-btn" bindtap="onQuantityChange" data-item-id="{{item.id}}" data-delta="-1">
                <text>-</text>
              </view>
              <text class="qty-value">{{item.quantity}}</text>
              <view class="qty-btn" bindtap="onQuantityChange" data-item-id="{{item.id}}" data-delta="1">
                <text>+</text>
              </view>
            </view>
            <text class="item-total">¥{{item.totalPrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 优惠券 -->
  <view class="section coupon-section">
    <view class="section-title">优惠券</view>
    <view class="coupon-select" bindtap="toggleCoupon">
      <text class="cs-label">{{selectedCoupon ? selectedCoupon.name : '不使用优惠券'}}</text>
      <text class="cs-arrow">{{showCoupon ? '-' : '>'}}</text>
    </view>
    <view wx:if="{{showCoupon && coupons.length > 0}}" class="coupon-dropdown">
      <view
        wx:for="{{coupons}}"
        wx:key="id"
        class="coupon-option"
        data-id="{{item.id}}"
        bindtap="onCouponTap"
      >
        <text>{{item.name}}</text>
        <text wx:if="{{couponId === item.id}}" class="check">✓</text>
      </view>
    </view>
    <view wx:if="{{showCoupon && coupons.length === 0}}" class="coupon-empty">
      <text>暂无可用优惠券</text>
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">商品合计</text>
      <text class="price-value">¥{{totalAmount}}</text>
    </view>
    <view wx:if="{{selectedCoupon}}" class="price-row">
      <text class="price-label">优惠减免</text>
      <text class="price-value text-green">-¥{{selectedCoupon.reduce}}</text>
    </view>
    <view class="price-row price-total">
      <text class="price-label">应付金额</text>
      <text class="price-value total-price">¥{{finalAmount}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section payment-section">
    <view class="section-title">支付方式</view>
    <view class="payment-option {{paymentMethod === 'wechat' ? 'active' : ''}}" data-method="wechat" bindtap="onPaymentTap">
      <text class="pay-icon">💚</text>
      <text class="pay-name">微信支付</text>
      <view wx:if="{{paymentMethod === 'wechat'}}" class="pay-check"></view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <view class="submit-info">
      <text class="si-label">合计：</text>
      <text class="si-value">¥{{finalAmount}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">提交订单</view>
  </view>
</view>
