/* pages/promotion/promotion.wxss */
.promotion-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

/* Banner */
.banner-swiper {
  width: 100%;
  height: 360rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.banner-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.banner-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ddd;
  transition: all 0.3s;
}

.dot.active {
  width: 32rpx;
  border-radius: 6rpx;
  background: #FF6B35;
}

/* 通用区块 */
.section {
  background: #fff;
  margin-top: 16rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.sparkle-icon {
  margin-right: 8rpx;
}

.fire-icon {
  margin-right: 8rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 新品推荐横向滚动 */
.new-scroll {
  white-space: nowrap;
}

.new-list {
  display: inline-flex;
  gap: 20rpx;
}

.new-card {
  width: 280rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid #f0f0f0;
}

.new-image {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.new-image text {
  font-size: 80rpx;
}

.new-info {
  padding: 16rpx 20rpx 20rpx;
}

.new-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.new-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.new-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
}

.new-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #FF6B35;
  font-weight: 600;
}

.price-num {
  font-size: 34rpx;
  color: #FF6B35;
  font-weight: 700;
}

.new-sales {
  font-size: 20rpx;
  color: #ccc;
}

/* 人气爆款横向滚动 */
.hot-scroll {
  white-space: nowrap;
}

.hot-list {
  display: inline-flex;
  gap: 20rpx;
}

.hot-card {
  width: 280rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  border: 2rpx solid #f0f0f0;
}

.hot-image {
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hot-image text {
  font-size: 80rpx;
}

.hot-info {
  padding: 16rpx 20rpx 20rpx;
}

.hot-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.hot-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-bottom {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 12rpx;
}

.hot-price {
  display: flex;
  align-items: baseline;
}

.hot-sales {
  font-size: 20rpx;
  color: #ccc;
}

/* 优惠券 */
.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #fff5f0;
  border: 2rpx dashed #FFB347;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  height: 140rpx;
  padding: 0 20rpx;
}

.coupon-card.received {
  opacity: 0.5;
}

.coupon-left {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  border-right: 2rpx dashed #FFB347;
  flex-shrink: 0;
}

.coupon-amount {
  color: #FF6B35;
}

.amount-num {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}

.amount-unit {
  font-size: 22rpx;
  margin-left: 4rpx;
}

.coupon-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: 20rpx;
  gap: 6rpx;
}

.coupon-condition text {
  font-size: 24rpx;
  color: #FF6B35;
}

.coupon-type {
  font-size: 20rpx;
  color: #999;
}

.coupon-btn {
  width: 120rpx;
  height: 44rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 22rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 6rpx;
}

.btn-disabled {
  background: #ccc !important;
}

/* 优惠券缺口 */
.coupon-cut-left,
.coupon-cut-right {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: #f5f5f5;
  border-radius: 50%;
  top: 50%;
  transform: translateY(-50%);
}

.coupon-cut-left {
  left: -10rpx;
}

.coupon-cut-right {
  right: -10rpx;
}

/* 新人专区 */
.new-user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FF6B35 0%, #FFB347 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  gap: 24rpx;
}

.nu-icon {
  font-size: 60rpx;
}

.nu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.nu-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.nu-btn {
  padding: 12rpx 32rpx;
  background: #fff;
  color: #FF6B35;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}
