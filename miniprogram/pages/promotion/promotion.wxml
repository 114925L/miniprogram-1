<!--pages/promotion/promotion.wxml-->
<view class="promotion-page">
  <!-- 轮播 Banner -->
  <swiper
    class="banner-swiper"
    autoplay
    interval="4000"
    circular
    bindchange="onBannerChange"
  >
    <swiper-item wx:for="{{banners}}" wx:key="id" data-index="{{index}}" bindtap="onBannerTap">
      <view class="banner-item" style="background: {{item.gradient}}">
        <text class="banner-emoji">{{item.image}}</text>
        <text class="banner-text">{{item.title}}</text>
      </view>
    </swiper-item>
  </swiper>
  <view class="banner-dots">
    <view
      wx:for="{{banners}}"
      wx:key="id"
      class="dot {{currentBanner === index ? 'active' : ''}}"
    ></view>
  </view>

  <!-- 新品推荐 -->
  <view class="section new-section">
    <view class="section-header">
      <view class="section-title">
        <text class="sparkle-icon">✨</text>
        <text>新品推荐</text>
      </view>
      <text class="section-more">查看全部 ></text>
    </view>
    <scroll-view scroll-x class="new-scroll">
      <view class="new-list">
        <view
          wx:for="{{newDrinks}}"
          wx:key="id"
          class="new-card"
          data-id="{{item.id}}"
          bindtap="onNewDrinkTap"
        >
          <view class="new-image placeholder-bg" style="background: {{item.bgGradient}}">
            <text>{{item.image}}</text>
          </view>
          <view class="new-info">
            <text class="new-name ellipsis">{{item.name}}</text>
            <text class="new-desc">{{item.description}}</text>
            <view class="new-bottom">
              <view class="new-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <text class="new-sales">已售 {{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 积分兑换推荐 -->
  <view class="section hot-section">
    <view class="section-header">
      <view class="section-title">
        <text class="fire-icon">🔥</text>
        <text>人气爆款</text>
      </view>
      <text class="section-more">查看全部 ></text>
    </view>
    <scroll-view scroll-x class="hot-scroll">
      <view class="hot-list">
        <view
          wx:for="{{hotDrinks}}"
          wx:key="id"
          class="hot-card"
          data-id="{{item.id}}"
          bindtap="onHotDrinkTap"
        >
          <view class="hot-image placeholder-bg" style="background: {{item.bgGradient}}">
            <text>{{item.image}}</text>
          </view>
          <view class="hot-info">
            <text class="hot-name ellipsis">{{item.name}}</text>
            <text class="hot-desc">{{item.description}}</text>
            <view class="hot-bottom">
              <view class="hot-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
              </view>
              <text class="hot-sales">已售 {{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 优惠券 -->
  <view class="section coupon-section">
    <view class="section-title">优惠券</view>
    <view class="coupon-list">
      <view
        wx:for="{{couponList}}"
        wx:key="id"
        class="coupon-card {{receivedIds.indexOf(item.id) > -1 ? 'received' : ''}}"
      >
        <view class="coupon-left">
          <view class="coupon-amount">
            <text class="amount-num">{{item.reduce}}</text>
            <text class="amount-unit">元</text>
          </view>
        </view>
        <view class="coupon-right">
          <view class="coupon-condition">
            <text>满{{item.threshold}}元可用</text>
          </view>
          <view class="coupon-type">{{item.type}}</view>
          <view
            class="coupon-btn {{receivedIds.indexOf(item.id) > -1 ? 'btn-disabled' : ''}}"
            data-id="{{item.id}}"
            bindtap="onReceiveCoupon"
          >
            {{receivedIds.indexOf(item.id) > -1 ? '已领取' : '领取'}}
          </view>
        </view>
        <view class="coupon-cut-left"></view>
        <view class="coupon-cut-right"></view>
      </view>
    </view>
  </view>

  <!-- 新人专享 -->
  <view class="section new-user-section">
    <view class="new-user-card">
      <text class="nu-icon">🎁</text>
      <view class="nu-info">
        <text class="nu-title">新人专享</text>
        <text class="nu-desc">首单立减 ¥5</text>
      </view>
      <view class="nu-btn" bindtap="onNewUserTap">立即查看</view>
    </view>
  </view>
</view>
