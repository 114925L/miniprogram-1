<!--pages/cart/cart.wxml-->
<view class="cart-page">
  <view wx:if="{{!empty}}" class="cart-list">
    <view
      wx:for="{{cartItems}}"
      wx:key="key"
      class="cart-item"
    >
      <view class="ci-left">
        <view class="ci-check {{item.checked !== false ? 'checked' : ''}}" bindtap="onItemCheck" data-key="{{item.key}}">
          <text class="check-icon">{{item.checked !== false ? '✓' : ''}}</text>
        </view>
        <view class="ci-image" bindtap="onCartTap" data-id="{{item.id}}" style="background: {{item.bgGradient}}">
          <text>{{item.image}}</text>
        </view>
      </view>
      <view class="ci-right">
        <view class="ci-name">{{item.name}}</view>
        <view class="ci-spec">
          <text wx:if="{{item.sweetness}}">{{item.sweetness}}</text>
          <text wx:if="{{item.sweetness && item.temperature}} / </text>
          <text wx:if="{{item.temperature}}">{{item.temperature}}</text>
          <text wx:if="{{item.size}} · {{item.size}}</text>
        </view>
        <view class="ci-bottom">
          <view class="ci-price">
            <text class="ci-price-symbol">¥</text>
            <text class="ci-price-value">{{item.totalPrice}}</text>
          </view>
          <view class="ci-qty">
            <view class="qty-btn" bindtap="onQuantityChange" data-key="{{item.key}}" data-delta="-1">
              <text>-</text>
            </view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn" bindtap="onQuantityChange" data-key="{{item.key}}" data-delta="1">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>
      <view class="ci-del" bindtap="onDelete" data-key="{{item.key}}">&times;</view>
    </view>
  </view>

  <view wx:if="{{empty}}" class="cart-empty">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <text class="empty-desc">快去挑选喜欢的饮品吧</text>
  </view>

  <!-- 底部结算栏 -->
  <view wx:if="{{!empty}}" class="cart-footer">
    <view class="cf-left">
      <view class="cf-all-check {{allChecked ? 'checked' : ''}}" bindtap="onAllCheck">
        <text class="check-icon">{{allChecked ? '✓' : ''}}</text>
      </view>
      <text class="cf-total">¥{{totalPrice}}</text>
    </view>
    <view class="cf-btn" bindtap="goToOrder">去结算({{totalQuantity}})</view>
  </view>
</view>
