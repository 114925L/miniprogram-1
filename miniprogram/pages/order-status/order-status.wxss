/* pages/order-status/order-status.wxss */
.status-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 成功区域 */
.success-section {
  background: linear-gradient(180deg, #FF6B35 0%, #FFB347 100%);
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-icon {
  margin-bottom: 30rpx;
}

.check-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.6);
  animation: scaleIn 0.5s ease-out;
}

@keyframes scaleIn {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.check-mark {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 信息卡片 */
.info-card {
  background: #fff;
  margin: -30rpx 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.card-label {
  font-size: 26rpx;
  color: #999;
}

.card-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.order-no {
  font-family: 'Courier New', monospace;
  color: #FF6B35;
  font-size: 26rpx;
}

.queue-info {
  display: flex;
  align-items: baseline;
}

.queue-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B35;
  line-height: 1;
}

.queue-text {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

.eta-info {
  display: flex;
  align-items: baseline;
}

.eta-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #52C41A;
  line-height: 1;
}

.eta-unit {
  font-size: 22rpx;
  color: #52C41A;
  margin-left: 8rpx;
}

.card-divider {
  height: 2rpx;
  background: #f5f5f5;
  margin: 0 0;
}

.countdown-row {
  padding-top: 24rpx;
}

.countdown-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B35;
  font-family: 'Courier New', monospace;
}

/* 进度 */
.progress-section {
  background: #fff;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 40rpx;
}

.progress-steps {
  display: flex;
  align-items: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.step-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.step.active .step-icon {
  background: #fff5f0;
  animation: pulse 1.5s infinite;
}

.step.done .step-icon {
  background: #f6ffed;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 107, 53, 0.3); }
  50% { box-shadow: 0 0 0 16rpx rgba(255, 107, 53, 0); }
}

.step-name {
  font-size: 22rpx;
  color: #999;
}

.step.active .step-name {
  color: #FF6B35;
  font-weight: 500;
}

.step.done .step-name {
  color: #52C41A;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #e8e8e8;
  margin: 0 16rpx;
  margin-bottom: 30rpx;
}

.step-line.done {
  background: #52C41A;
}

/* 温馨提示 */
.tips-section {
  background: #fffbe6;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  margin-bottom: 4rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 底部按钮 */
.action-area {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-home {
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
}

.btn-continue {
  background: #FF6B35;
  color: #fff;
}

.btn:active {
  opacity: 0.85;
}
