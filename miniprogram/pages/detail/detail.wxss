/* pages/detail/detail.wxss */
.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 商品大图 */
.detail-hero {
  width: 100%;
}

.hero-image {
  width: 100%;
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-image text {
  font-size: 160rpx;
}

/* 基本信息 */
.detail-basic {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.detail-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #FF6B35;
  margin-right: 20rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.detail-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: #999;
}

.detail-meta text {
  margin-right: 16rpx;
}

/* 通用区块 */
.detail-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 成分标签 */
.ingredients-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ingredient-tag {
  background: #fff5f0;
  color: #FF6B35;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 规格按钮 */
.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-btn {
  padding: 16rpx 36rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.spec-btn.active {
  border-color: #FF6B35;
  color: #FF6B35;
  background: #fff5f0;
}

/* 容量 */
.size-options {
  display: flex;
  gap: 20rpx;
}

.size-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.size-btn.active {
  border-color: #FF6B35;
  background: #fff5f0;
}

.size-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.size-price {
  font-size: 22rpx;
  color: #999;
}

.size-btn.active .size-price {
  color: #FF6B35;
}

/* 加料 */
.topping-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.topping-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 28rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.topping-btn.active {
  border-color: #FF6B35;
  background: #fff5f0;
}

.topping-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.topping-price {
  font-size: 22rpx;
  color: #FF6B35;
}

/* 数量 */
.quantity-row {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e5e5;
  border-radius: 50%;
  font-size: 36rpx;
  color: #FF6B35;
}

.qty-btn:active {
  background: #fff5f0;
}

.qty-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 200;
}

.bar-left {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  position: relative;
}

.bar-price {
  display: flex;
  align-items: baseline;
}

.bar-price-symbol {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 600;
}

.bar-price-value {
  font-size: 44rpx;
  color: #FF6B35;
  font-weight: 700;
}

.bar-cart {
  position: relative;
}

.cart-anim-text {
  position: absolute;
  top: -20rpx;
  right: -30rpx;
  font-size: 20rpx;
  color: #FF6B35;
  font-weight: 600;
  animation: floatUp 0.6s ease-out;
}

@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-30rpx); }
}

.bar-right {
  display: flex;
  gap: 16rpx;
}

.btn {
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-cart {
  background: #FFB347;
  color: #fff;
  padding: 0 32rpx;
}

.btn-buy {
  background: #FF6B35;
  color: #fff;
  padding: 0 40rpx;
}

.btn:active {
  opacity: 0.85;
}

.safe-bottom {
  height: 120rpx;
}
