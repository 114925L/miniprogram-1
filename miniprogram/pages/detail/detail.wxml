<!--pages/detail/detail.wxml-->
<view class="detail-page">
  <view wx:if="{{drink}}">
    <!-- 商品大图 -->
    <view class="detail-hero">
      <view class="hero-image placeholder-bg" style="background: {{drink.bgGradient}}">
        <text>{{drink.image}}</text>
      </view>
    </view>

    <!-- 基本信息 -->
    <view class="detail-basic">
      <view class="price-row">
        <text class="detail-price">¥{{drink.price}}</text>
        <text class="detail-name">{{drink.name}}</text>
      </view>
      <text class="detail-desc">{{drink.description}}</text>
      <view class="detail-meta">
        <text>月售 {{drink.sales}}+</text>
        <text wx:if="{{drink.isHot}}">· 热门</text>
        <text wx:if="{{drink.isNew}}">· 新品</text>
        <text>· 收藏 {{drink.favorites}}</text>
      </view>
    </view>

    <!-- 成分说明 -->
    <view class="detail-section">
      <view class="section-title">主要成分</view>
      <view class="ingredients-list">
        <view wx:for="{{drink.ingredients}}" wx:key="*this" class="ingredient-tag">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 甜度选择 -->
    <view wx:if="{{drink.specs.sweetness}}" class="detail-section">
      <view class="section-title">甜度</view>
      <view class="spec-options">
        <view
          wx:for="{{sweetnessOptions}}"
          wx:key="*this"
          class="spec-btn {{selectedSweetness === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onSweetnessTap"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 温度选择 -->
    <view wx:if="{{drink.specs.temperature}}" class="detail-section">
      <view class="section-title">温度</view>
      <view class="spec-options">
        <view
          wx:for="{{temperatureOptions}}"
          wx:key="*this"
          class="spec-btn {{selectedTemperature === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onTemperatureTap"
        >
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 容量选择 -->
    <view class="detail-section">
      <view class="section-title">容量</view>
      <view class="size-options">
        <view
          wx:for="{{sizes}}"
          wx:key="name"
          class="size-btn {{selectedSize === item.name ? 'active' : ''}}"
          data-index="{{index}}"
          bindtap="onSizeTap"
        >
          <text class="size-name">{{item.name}}</text>
          <text class="size-price">{{item.extraPrice > 0 ? '+¥' + item.extraPrice : '标准价'}}</text>
        </view>
      </view>
    </view>

    <!-- 加料选择 -->
    <view class="detail-section">
      <view class="section-title">加料</view>
      <view class="topping-grid">
        <view
          wx:for="{{toppings}}"
          wx:key="name"
          class="topping-btn {{selectedToppings.indexOf(item.name) > -1 ? 'active' : ''}}"
          data-name="{{item.name}}"
          bindtap="onToppingTap"
        >
          <text class="topping-name">{{item.name}}</text>
          <text class="topping-price">+¥{{item.price}}</text>
        </view>
      </view>
    </view>

    <!-- 数量 -->
    <view class="detail-section">
      <view class="section-title">数量</view>
      <view class="quantity-row">
        <view class="qty-btn" bindtap="onQuantityChange" data-delta="-1">
          <text>-</text>
        </view>
        <text class="qty-value">{{quantity}}</text>
        <view class="qty-btn" bindtap="onQuantityChange" data-delta="1">
          <text>+</text>
        </view>
      </view>
    </view>

    <!-- 底部安全区 -->
    <view class="safe-bottom"></view>
  </view>

  <!-- 底部操作栏 -->
  <view wx:if="{{drink}}" class="bottom-bar">
    <view class="bar-left">
      <view class="bar-price">
        <text class="bar-price-symbol">¥</text>
        <text class="bar-price-value">{{totalPrice}}</text>
      </view>
      <view class="bar-cart" wx:if="{{showCartAnim}}">
        <text class="cart-anim-text">+1</text>
      </view>
    </view>
    <view class="bar-right">
      <view class="btn btn-cart" bindtap="addToCart">加入购物车</view>
      <view class="btn btn-buy" bindtap="buyNow">立即购买</view>
    </view>
  </view>
</view>
